{
  "cli": {
    "version": ">= 13.4.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "APP_VARIANT": "dev" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "APP_VARIANT": "staging" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "APP_VARIANT": "prod" }
    }
  },
  "submit": {
    "production": {}
  }
}
