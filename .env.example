# ─────────────────────────────────────────────────────────────────────────────
# Oberon Prime — mobile/web app environment
#
# This app reads only these vars (see app.config.ts). They are consumed at
# BUILD TIME and baked into the bundle — there is no runtime env in a static
# web build or a native binary. To change the API URL later, redeploy/rebuild.
#
# Easypanel (web): paste these into the service's "Environment Variables" box;
# Easypanel forwards them to the Docker build as build args.
# ─────────────────────────────────────────────────────────────────────────────

# Selects the environment to build for. Leave as "prod" for a live deploy.
APP_VARIANT=prod

# The backend the app should talk to (no trailing slash). Point this at your API.
API_ORIGIN_PROD=https://your-api-domain.com

# Optional — only needed if you also build staging/dev variants:
# API_ORIGIN_STAGING=https://staging.api.your-domain.com
# API_ORIGIN_DEV=http://localhost:3000
